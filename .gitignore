*.py[cod]
*.so
*.pyd
.venv/
dist/
wheelhouse/
*.egg-info/
.pytest_cache/

# Editors / OS
.idea/
.vscode/
.DS_Store

# Devbox / direnv
.devbox/
.env

# Coverage
coverage/
*.profraw
lcov.info
