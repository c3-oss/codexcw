root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.go]
indent_style = tab

[*.{rs,py}]
indent_size = 4

[*.{yml,yaml,json,jsonc,toml,js,cjs,mjs,ts,tsx,html,css}]
indent_size = 2

[*.md]
indent_size = 2

[*.sh]
indent_size = 4

[{Makefile,.justfile}]
indent_style = tab
